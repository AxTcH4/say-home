// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}


//********************************
//            Modèls
//********************************


model User {
  id          Int      @id @default(autoincrement())
  firstName   String
  lastName    String
  email       String   @unique
  password    String
  role        Role
  createdAt   DateTime @default(now())

  properties   Property[]
  appointments Appointment[]
  notifications Notification[]
}

enum Role {
  ADMIN
  AGENT
}


//*********CRM********

model Prospect {
  id          Int      @id @default(autoincrement())
  firstName   String
  lastName    String
  email       String   @unique
  phone       String?
  budget      Float?
  createdAt   DateTime @default(now())

  stageId Int
  stage   PipelineStage @relation(fields: [stageId], references: [id])

  appointments Appointment[]
  tickets      Ticket[]
  chatSessions ChatSession[]
  leadScores   LeadScore[]
  matchRuns    MatchRun[]
}

model PipelineStage {
  id    Int    @id @default(autoincrement())
  name  String

  prospects Prospect[]
}


//*********Proprieties********

model Property {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  price       Float
  createdAt   DateTime @default(now())

  agentId Int
  agent   User @relation(fields: [agentId], references: [id])

  media        PropertyMedia[]
  appointments Appointment[]
  matchResults MatchResult[]
}

model PropertyMedia {
  id         Int    @id @default(autoincrement())
  url        String
  type       String

  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id])
}

//*********RDV********

model Appointment {
  id        Int      @id @default(autoincrement())
  date      DateTime
  status    AppointmentStatus
  createdAt DateTime @default(now())

  prospectId Int
  propertyId Int
  agentId    Int

  prospect Prospect @relation(fields: [prospectId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])
  agent    User     @relation(fields: [agentId], references: [id])
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

//*********Module IA********


model MatchRun {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  prospectId Int
  prospect   Prospect @relation(fields: [prospectId], references: [id])

  results MatchResult[]
}

model MatchResult {
  id        Int     @id @default(autoincrement())
  score     Float

  matchRunId Int
  propertyId Int

  matchRun MatchRun @relation(fields: [matchRunId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])
}

model LeadScore {
  id        Int      @id @default(autoincrement())
  score     Float
  createdAt DateTime @default(now())

  prospectId Int
  prospect   Prospect @relation(fields: [prospectId], references: [id])
}

//*********Chatbot SAV********


model ChatSession {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  prospectId Int
  prospect   Prospect @relation(fields: [prospectId], references: [id])

  messages ChatMessage[]
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  content   String
  sender    String   // "agent" or "prospect"
  createdAt DateTime @default(now())

  sessionId Int
  session   ChatSession @relation(fields: [sessionId], references: [id])
}

model Ticket {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  status      TicketStatus
  createdAt   DateTime @default(now())

  prospectId Int
  prospect   Prospect @relation(fields: [prospectId], references: [id])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}


model AutomationRule {
  id        Int    @id @default(autoincrement())
  name      String
  condition String  // can store logic (later: JSON)
  action    String
}

model Notification {
  id        Int      @id @default(autoincrement())
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id])
}